<% content_for :title, "#{@session.youtube_url.sub(%r{^https?://(www\.)?}, "")}" %>
<% content_for :og_image, ("https://i.ytimg.com/vi/#{@session.video_id}/maxresdefault.jpg" if @session.video_id.present?) %>
<%= turbo_stream_from @session, :timeline %>

<div data-controller="replay autoscroll highlighter"
     data-replay-autoplay-value="<%= @autoplay_replay %>"
     data-replay-video-id-value="<%= @session.show_video? ? @session.video_id : "" %>">
  <header class="sticky top-0 z-20 bg-white dark:bg-gray-950 border-b-[3px] border-black dark:border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
      <div class="min-w-0 flex items-center gap-3">
        <%= render "shared/brand" %>
        <span class="text-gray-300 dark:text-gray-700">/</span>
        <div class="min-w-0">
          <h1 class="text-base font-black truncate max-w-sm" title="<%= @session.youtube_url %>"><%= @session.youtube_url.sub(%r{^https?://(www\.)?}, "") %></h1>
          <div class="text-[10px] font-mono text-gray-500 dark:text-gray-400 uppercase">
            <% if @session.running? %>
              live
            <% elsif @session.stopped_at %>
              ended <%= time_ago_in_words(@session.stopped_at) %> ago
            <% end %>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <% if @turns.any? %>
          <button type="button" data-action="replay#start" class="px-4 py-2 rounded-xl bg-purple-400 text-black font-black text-xs border-[3px] border-black dark:border-gray-100 shadow-[3px_3px_0_0_rgba(0,0,0,1)] dark:shadow-[3px_3px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition">REPLAY</button>
        <% end %>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-6 space-y-6">
    <% if @session.show_video? %>
      <details open class="group fixed top-20 right-6 z-30 rounded-2xl border-[3px] border-black dark:border-gray-100 shadow-[6px_6px_0_0_rgba(0,0,0,1)] dark:shadow-[6px_6px_0_0_rgba(255,255,255,0.2)] bg-white dark:bg-gray-900 overflow-hidden">
        <summary class="cursor-pointer list-none px-3 py-2 flex items-center justify-between gap-3 font-black text-xs uppercase tracking-wider select-none">
          <span class="flex items-center gap-2">
            <span class="size-2 rounded-full bg-red-500 animate-pulse"></span>
            <span class="group-open:hidden inline">Watching</span>
            <span class="group-open:inline hidden">Video</span>
          </span>
          <span class="text-lg leading-none">
            <span class="group-open:inline hidden">−</span>
            <span class="group-open:hidden inline">+</span>
          </span>
        </summary>
        <div class="aspect-video w-80 bg-black">
          <div data-replay-target="video" class="w-full h-full"></div>
        </div>
      </details>
    <% end %>

    <%= render "stream_sessions/timeline", turns: @turns, autoplay: @autoplay_replay %>
  </main>
</div>
