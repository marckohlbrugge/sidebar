<div data-controller="mic-recorder"
     data-mic-recorder-socket-url-value="<%= "#{request.ssl? ? "wss" : "ws"}://#{request.host_with_port}/sessions/#{session.token}/ingest" %>"
     data-mic-recorder-worklet-url-value="/pcm_worklet.js"
     class="p-6 rounded-2xl bg-yellow-200 dark:bg-yellow-300 text-black flex flex-col sm:flex-row sm:items-center gap-4">
  <div class="flex-1 min-w-0">
    <div class="font-black text-lg">🎤 Audio session</div>
    <div data-mic-recorder-target="status" class="text-sm font-medium">
      Record from your microphone or share audio from another tab. Keep this page open while recording.
    </div>
  </div>
  <div class="flex items-center gap-2 shrink-0">
    <button type="button"
            data-mic-recorder-target="micButton"
            data-action="mic-recorder#startMic"
            class="px-5 py-3 rounded-xl bg-green-400 text-black font-black border-[3px] border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer">
      ● MIC
    </button>
    <button type="button"
            data-mic-recorder-target="tabButton"
            data-action="mic-recorder#startTab"
            title="Share audio from another browser tab (Chrome/Edge)"
            class="px-5 py-3 rounded-xl bg-white text-black font-black border-[3px] border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer">
      🔊 TAB
    </button>
    <button type="button"
            data-mic-recorder-target="stopButton"
            data-action="mic-recorder#stop"
            hidden
            class="px-6 py-3 rounded-xl bg-red-500 text-white font-black border-[3px] border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer">
      ■ STOP
    </button>
  </div>
</div>
