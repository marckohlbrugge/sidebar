<div class="max-w-xl mx-auto px-6 py-12 space-y-6">
  <%= render "shared/brand" %>
  <div>
    <h1 class="text-4xl font-black tracking-tight mt-1">Start a session</h1>
    <p class="text-gray-600 dark:text-gray-300 mt-2 font-medium leading-snug">
      You've been invited to try Armchair. Pick an audio source — your mic or a browser tab (YouTube, podcast, livestream playing elsewhere), or paste a URL we'll stream server-side (X Spaces, direct HLS, any yt-dlp source). Keep the session page open while it runs.
    </p>
  </div>

  <div class="p-4 rounded-xl bg-gray-100 dark:bg-gray-900/60 text-sm font-medium space-y-1">
    <div><%= @invite.max_sessions - @invite.sessions_used %> of <%= @invite.max_sessions %> sessions left · capped at <%= @invite.max_turns_per_session %> turns each.</div>
    <div class="text-gray-600 dark:text-gray-400">Audio streams straight to the transcription service — not recorded or stored.</div>
  </div>

  <%= form_with model: @session, url: invited_stream_sessions_path, class: "space-y-4", data: { controller: "source-picker" } do |f| %>
    <div class="grid grid-cols-2 gap-3">
      <% [[ "microphone", "🎤 Mic / Tab", "Capture in this browser." ], [ "url", "🔗 Stream URL", "HLS, Icecast, or any yt-dlp source." ]].each do |value, label, hint| %>
        <label class="flex items-start gap-3 p-4 rounded-xl border-[3px] border-black dark:border-gray-100 bg-white dark:bg-gray-900 shadow-[3px_3px_0_0_rgba(0,0,0,1)] dark:shadow-[3px_3px_0_0_rgba(255,255,255,0.15)] cursor-pointer has-[:checked]:bg-yellow-200 dark:has-[:checked]:bg-yellow-300 has-[:checked]:text-black">
          <%= f.radio_button :source_kind, value, checked: (@session.source_kind || "microphone") == value, data: { action: "change->source-picker#switch" }, class: "mt-1" %>
          <div>
            <div class="font-black text-sm"><%= label %></div>
            <div class="text-[11px] text-gray-500 dark:text-gray-400 font-medium"><%= hint %></div>
          </div>
        </label>
      <% end %>
    </div>

    <div data-source-picker-target="urlField" class="<%= "hidden" if @session.source_microphone? %>">
      <%= f.text_field :youtube_url,
            placeholder: "https://x.com/.../status/... or https://example.com/stream.m3u8",
            disabled: @session.source_microphone?,
            data: { source_picker_target: "urlInput" },
            class: "w-full px-4 py-3 rounded-xl border-[3px] border-black dark:border-gray-100 bg-white dark:bg-gray-900 font-medium text-base shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.15)] focus:outline-none focus:translate-x-0.5 focus:translate-y-0.5 focus:shadow-none transition disabled:opacity-50" %>
    </div>

    <%= f.submit "START SESSION", class: "px-6 py-3 rounded-xl bg-green-400 text-black font-black text-sm border-[3px] border-black dark:border-gray-100 shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer" %>
  <% end %>

  <div>
    <%= link_to "← back to home", root_path, class: "text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
  </div>
</div>
