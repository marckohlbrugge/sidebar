<div class="max-w-4xl mx-auto px-6 py-12 space-y-12">
  <section class="space-y-4">
    <div class="flex items-center gap-5">
      <%= image_tag "icon.png", class: "size-24 rounded-2xl" %>
      <h1 class="text-6xl font-black tracking-tight">Armchair</h1>
    </div>
    <p class="text-xl font-medium text-gray-700 dark:text-gray-300 max-w-2xl leading-snug">
      A real-time AI sidebar for live podcasts. Four armchair critics watch the conversation and chime in — a stern producer, an encyclopedic context guy, a comedy writer, and a cynical troll.
    </p>
    <div class="flex items-center gap-3 pt-2">
      <%= link_to "manage", manage_stream_sessions_path, class: "text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
    </div>
  </section>

  <% if @demos.any? %>
    <section class="space-y-4">
      <h2 class="text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-400">Examples</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @demos.each do |session| %>
          <li>
            <%= link_to stream_session_path(session, replay: 1), class: "block p-5 rounded-2xl border-[3px] border-black dark:border-gray-100 bg-white dark:bg-gray-900 shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.15)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition" do %>
              <div class="flex items-start gap-3">
                <div class="size-12 shrink-0 rounded-xl bg-purple-400 text-black flex items-center justify-center font-black text-lg border-2 border-black dark:border-gray-100">▶</div>
                <div class="min-w-0">
                  <div class="font-black text-base truncate"><%= session.youtube_url %></div>
                  <div class="text-[10px] font-mono text-gray-500 dark:text-gray-400 uppercase mt-1"><%= session.turns.count %> turns</div>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>
