<%= turbo_stream_from @session, :timeline %>
<%= turbo_stream_from @session, :events %>

<div data-controller="replay autoscroll debug-toggle highlighter">
  <header class="sticky top-0 z-20 bg-white dark:bg-gray-950 border-b-[3px] border-black dark:border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
      <div class="min-w-0 flex items-center gap-3">
        <%= render "shared/brand" %>
        <span class="text-gray-300 dark:text-gray-700">/</span>
        <%= link_to "manage", manage_stream_sessions_path, class: "text-xs font-bold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
        <span class="text-gray-300 dark:text-gray-700">/</span>
        <h1 class="text-base font-black truncate max-w-sm" title="<%= @session.source_microphone? ? "Microphone" : @session.youtube_url %>">
          <% if @session.source_microphone? %>🎤 Microphone<% else %><%= @session.youtube_url.sub(%r{^https?://(www\.)?}, "") %><% end %>
        </h1>
        <div class="text-[10px] font-mono text-gray-500 dark:text-gray-400 uppercase mt-0.5">
          <%= @session.status %><%= " · pid #{@session.pid}" if @session.process_alive? %>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <%= link_to "EDIT", edit_manage_stream_session_path(@session), class: "px-4 py-2 rounded-xl bg-gray-100 dark:bg-gray-800 text-black dark:text-white font-black text-xs border-[3px] border-black dark:border-gray-100 shadow-[3px_3px_0_0_rgba(0,0,0,1)] dark:shadow-[3px_3px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition" %>
        <% if @session.process_alive? %>
          <%= button_to "STOP", manage_stream_session_ingest_path(@session), method: :delete, class: "px-4 py-2 rounded-xl bg-red-500 text-white font-black text-xs border-[3px] border-black dark:border-gray-100 shadow-[3px_3px_0_0_rgba(0,0,0,1)] dark:shadow-[3px_3px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition" %>
        <% end %>
        <% if @turns.any? %>
          <button type="button" data-action="replay#start" class="px-4 py-2 rounded-xl bg-purple-400 text-black font-black text-xs border-[3px] border-black dark:border-gray-100 shadow-[3px_3px_0_0_rgba(0,0,0,1)] dark:shadow-[3px_3px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition">REPLAY</button>
        <% end %>
<button type="button" data-action="debug-toggle#toggle" class="px-3 py-1.5 rounded-lg border-2 border-gray-300 dark:border-gray-600 text-[10px] font-bold text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800">DEBUG</button>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-6 space-y-6">
    <% if @session.source_microphone? %>
      <div data-controller="mic-recorder"
           data-mic-recorder-socket-url-value="<%= "#{request.ssl? ? "wss" : "ws"}://#{request.host_with_port}/sessions/#{@session.token}/ingest" %>"
           data-mic-recorder-worklet-url-value="/pcm_worklet.js"
           class="p-6 rounded-2xl border-[3px] border-black dark:border-gray-100 bg-yellow-200 dark:bg-yellow-300 text-black flex items-center justify-between gap-4">
        <div>
          <div class="font-black text-lg">🎤 Microphone session</div>
          <div data-mic-recorder-target="status" class="text-sm font-medium">Click START to begin — this page has to stay open while you record.</div>
        </div>
        <button type="button" data-mic-recorder-target="button" data-action="mic-recorder#toggle"
                class="px-6 py-3 rounded-xl bg-green-400 text-black font-black border-[3px] border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer">
          ● START RECORDING
        </button>
      </div>
    <% end %>

    <%= render "stream_sessions/timeline", turns: @turns %>

    <div data-empty-state class="p-8 rounded-2xl border-[3px] border-dashed border-gray-300 dark:border-gray-700 text-center text-gray-500 dark:text-gray-400 font-medium">
      <% if @session.source_microphone? %>
        No turns yet. Start recording and speak for a few seconds.
      <% elsif @session.process_alive? %>
        Transcribing… turns will appear as they arrive.
      <% elsif @session.pid.present? %>
        Ingest exited without producing turns. Check <code class="text-xs"><%= @session.log_path %></code> for details.
      <% else %>
        Ingest never started. Try creating the session again.
      <% end %>
    </div>

    <section data-debug-toggle-target="panel" class="hidden space-y-4 mt-8">
      <% if @session.video_id.present? %>
        <div class="aspect-video w-full rounded-2xl overflow-hidden bg-black border-[3px] border-black shadow-[6px_6px_0_0_rgba(0,0,0,1)]">
          <iframe
            src="https://www.youtube.com/embed/<%= @session.video_id %>?autoplay=1&mute=1"
            class="w-full h-full"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      <% end %>

      <div>
        <h2 class="font-black mb-2 text-xs uppercase tracking-wider text-gray-500">Raw events</h2>
        <ul id="events" class="space-y-0.5 text-[11px] font-mono text-gray-500 max-h-64 overflow-auto border-2 border-gray-200 rounded-lg p-2">
          <%= render partial: "transcript_events/transcript_event", collection: @events, as: :transcript_event %>
        </ul>
      </div>
    </section>
  </main>
</div>
