<div class="max-w-xl mx-auto px-6 py-6 space-y-6">
  <%= render "shared/brand" %>
  <div>
    <%= link_to "← back", manage_stream_sessions_path, class: "text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
    <h1 class="text-4xl font-black tracking-tight mt-1">New Session</h1>
    <p class="text-gray-600 dark:text-gray-300 mt-2 font-medium">Record from this browser's microphone, or paste a URL — a direct audio stream (HLS .m3u8, Icecast) or any page yt-dlp can handle (X/Twitter Spaces, YouTube, Twitch, …).</p>
  </div>

  <%= form_with model: @session, url: manage_stream_sessions_path, class: "space-y-4", data: { controller: "source-picker" } do |f| %>
    <div class="grid grid-cols-2 gap-3">
      <% [[ "microphone", "🎤 Microphone", "Record from this browser." ], [ "url", "🔗 Stream URL", "HLS, Icecast, or any yt-dlp source." ]].each do |value, label, hint| %>
        <label class="flex items-start gap-3 p-4 rounded-xl border-[3px] border-black dark:border-gray-100 bg-white dark:bg-gray-900 shadow-[3px_3px_0_0_rgba(0,0,0,1)] dark:shadow-[3px_3px_0_0_rgba(255,255,255,0.15)] cursor-pointer has-[:checked]:bg-yellow-200 dark:has-[:checked]:bg-yellow-300 has-[:checked]:text-black">
          <%= f.radio_button :source_kind, value, checked: (@session.source_kind || "url") == value, data: { action: "change->source-picker#switch" }, class: "mt-1" %>
          <div>
            <div class="font-black text-sm"><%= label %></div>
            <div class="text-[11px] text-gray-500 dark:text-gray-400 font-medium"><%= hint %></div>
          </div>
        </label>
      <% end %>
    </div>

    <div data-source-picker-target="urlField" class="<%= "hidden" if @session.source_microphone? %>">
      <%= f.text_field :youtube_url,
            placeholder: "https://example.com/stream.m3u8",
            disabled: @session.source_microphone?,
            data: { source_picker_target: "urlInput" },
            class: "w-full px-4 py-3 rounded-xl border-[3px] border-black dark:border-gray-100 bg-white dark:bg-gray-900 font-medium text-base shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.15)] focus:outline-none focus:translate-x-0.5 focus:translate-y-0.5 focus:shadow-none transition disabled:opacity-50" %>
    </div>

    <%= f.submit "CREATE", class: "px-5 py-2.5 rounded-xl bg-green-400 text-black font-black text-sm border-[3px] border-black dark:border-gray-100 shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer" %>
  <% end %>
</div>
