<div class="max-w-xl mx-auto px-6 py-6 space-y-6">
  <%= render "shared/brand" %>
  <div>
    <%= link_to "← back", [ :manage, @session ], class: "text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
    <h1 class="text-4xl font-black tracking-tight mt-1">Edit Session</h1>
    <p class="text-gray-600 dark:text-gray-300 mt-2 font-medium">
      <% if @session.source_microphone? %>
        This is a microphone session — nothing to edit besides deletion.
      <% else %>
        Update the stream URL for this session.
      <% end %>
    </p>
  </div>

  <% unless @session.source_microphone? %>
    <%= form_with model: @session, url: manage_stream_session_path(@session), class: "space-y-4" do |f| %>
      <%= f.text_field :youtube_url,
            placeholder: "https://example.com/stream.m3u8",
            class: "w-full px-4 py-3 rounded-xl border-[3px] border-black dark:border-gray-100 bg-white dark:bg-gray-900 font-medium text-base shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.15)] focus:outline-none focus:translate-x-0.5 focus:translate-y-0.5 focus:shadow-none transition" %>
      <%= f.submit "SAVE", class: "px-5 py-2.5 rounded-xl bg-green-400 text-black font-black text-sm border-[3px] border-black dark:border-gray-100 shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition cursor-pointer" %>
    <% end %>
  <% end %>

  <%= button_to "DELETE SESSION", manage_stream_session_path(@session), method: :delete, data: { turbo_confirm: "Delete this session and all of its turns/comments/events?" }, class: "px-5 py-2.5 rounded-xl bg-red-500 text-white font-black text-sm border-[3px] border-black dark:border-gray-100 shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.2)] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition" %>
</div>
